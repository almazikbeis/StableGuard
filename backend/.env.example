# Required
ANTHROPIC_API_KEY=sk-ant-...

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=GPSJJqicuDSJ6LXhEZpmUboThjzdefG5wZAZkL2hd7es
WALLET_KEY_PATH=~/.config/solana/devnet.json

# Pyth
PYTH_HERMES_URL=https://hermes.pyth.network

# Server
PORT=8080

# Autonomous yield execution (trusted strategy token accounts)
YIELD_ENABLED=false
YIELD_MIN_APY=4.0
YIELD_ENTRY_RISK=35
YIELD_EXIT_RISK=55
YIELD_DEPOSIT_AMOUNT=1000
YIELD_STRATEGY_USDC_ACCOUNT=
YIELD_STRATEGY_USDT_ACCOUNT=
YIELD_STRATEGY_DAI_ACCOUNT=
YIELD_STRATEGY_PYUSD_ACCOUNT=
YIELD_KAMINO_USDC_VAULT=
YIELD_KAMINO_USDT_VAULT=
YIELD_KAMINO_DAI_VAULT=
YIELD_KAMINO_PYUSD_VAULT=

# AI decision runtime
AI_AGENT_MODEL=claude-haiku-4-5
AI_DECISION_PROFILE=balanced

# Autonomous market execution guardrails
EXECUTION_APPROVAL_MODE=manual
EXECUTION_MAX_SLIPPAGE_BPS=50
EXECUTION_MAX_PRICE_IMPACT_PCT=1.5
EXECUTION_MAX_ROUTE_HOPS=3
EXECUTION_AUTO_SETTLE=true

# Optional growth sleeve (higher-beta assets outside the stablecoin core)
GROWTH_SLEEVE_ENABLED=false
GROWTH_SLEEVE_BUDGET_PCT=0
GROWTH_SLEEVE_MAX_ASSET_PCT=0
GROWTH_SLEEVE_ALLOWED_ASSETS=SOL,WBTC,WETH,JITOSOL
GROWTH_SLEEVE_LIVE_EXECUTION=false
